PORT=8080
WALLETS_CONFIG=wallets.config
STORE_PATH=copied_trades.json
COPY_AMOUNT_USD=10
SCAN_INTERVAL_MIN=5

# Your wallet address (required for /balance endpoint)
USER_ADDRESS=0x...

# Optional — set these to enable live order placement
# POLY_PRIVATE_KEY=0x...
# POLY_API_KEY=...
# POLY_API_SECRET=...
# POLY_API_PASSPHRASE=...
